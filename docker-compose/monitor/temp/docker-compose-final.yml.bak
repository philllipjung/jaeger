# Docker Compose with Data Prepper for Hybrid Prometheus + OpenSearch Metrics
# Based on configuration from /home/philip/Downloads

services:
  # ========== OPENSEARCH ==========
  opensearch:
    image: opensearchproject/opensearch:3.5.0@sha256:2f2244c7c0ad3a4a0d09977c2b519977b77bacc92e1eaf995c080c1d22f517b6
    container_name: opensearch
    networks:
      - backend
    environment:
      - discovery.type=single-node
      - bootstrap.memory_lock=true
      - "OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m"
      - "DISABLE_INSTALL_DEMO_CONFIG=true"
      - DISABLE_SECURITY_DASHBOARDS_PLUGIN=true
      - plugins.security.disabled=true
      - http.host=0.0.0.0
      - transport.host=127.0.0.1
    ulimits:
      memlock:
        soft: -1
        hard: -1
      nofile:
        soft: 65536
        hard: 65536
    ports:
      - "9200:9200"
      - "9600:9600"
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:9200 || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 30

  # ========== OPENSEARCH DASHBOARDS ==========
  opensearch-dashboards:
    image: opensearchproject/opensearch-dashboards:3.5.0
    container_name: opensearch-dashboards
    networks:
      - backend
    ports:
      - "5601:5601"
    environment:
      OPENSEARCH_HOSTS: '["http://opensearch:9200"]'
      DISABLE_SECURITY_DASHBOARDS_PLUGIN: "true"
    depends_on:
      opensearch:
        condition: service_healthy

  # ========== JAEGER ==========
  jaeger:
    image: jaegertracing/jaeger:${JAEGER_VERSION:-latest}
    container_name: jaeger
    networks:
      backend:
        aliases: [spm_metrics_source]
    volumes:
      - "./jaeger-ui.json:/etc/jaeger/jaeger-ui.json"
      - "../../cmd/jaeger/config-spm-opensearch.yaml:/etc/jaeger/config.yml"
    command: ["--config", "/etc/jaeger/config.yml"]
    ports:
      - "16686:16686" # Jaeger UI
      - "8888:8888"   # Prometheus metrics
      # OTLP removed - traces go through OTEL Collector instead
    depends_on:
      opensearch:
        condition: service_healthy

  # ========== PROMETHEUS ==========
  prometheus:
    image: prom/prometheus:v3.9.1@sha256:1f0f50f06acaceb0f5670d2c8a658a599affe7b0d8e78b898c1035653849a702
    container_name: prometheus
    networks:
      - backend
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --web.enable-remote-write-receiver
      - --enable-feature=exemplar-storage
      - --enable-feature=native-histograms
      - --storage.tsdb.retention.time=30d
    volumes:
      - "./prometheus-data-prepper.yml:/etc/prometheus/prometheus.yml"
      - prometheus-data:/prometheus
    ports:
      - "9090:9090"

  # ========== DATA PREPPER ==========
  data-prepper:
    image: opensearchproject/data-prepper:latest
    container_name: data-prepper
    networks:
      - backend
    volumes:
      - "./data-prepper-pipelines.yaml:/usr/share/data-prepper/pipelines/data-prepper-pipelines.yaml"
      - "./data-prepper-config-fixed.yaml:/usr/share/data-prepper/config/data-prepper-config.yaml"
    ports:
      - "2021:2021"    # HTTP server
      - "21890:21890"  # OTLP trace source
      - "21891:21891"  # OTLP metrics source
      - "4900:4900"    # Pipeline health check
    expose:
      - "2021"
      - "4900"
      - "21891"
      - "21890"
    depends_on:
      opensearch:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -f http://localhost:4900/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 10

  # ========== OTEL COLLECTOR ==========
  otel-collector:
    image: otel/opentelemetry-collector-contrib:0.131.0
    container_name: otel-collector
    networks:
      - backend
    user: "0:0"
    command: ["--config=/etc/otel-collector-config.yml"]
    volumes:
      - "./otel-collector-config-fixed.yml:/etc/otel-collector-config.yml"
      - /var/run/docker.sock:/var/run/docker.sock
      - /sys/kernel/debug:/sys/kernel/debug
      - /proc:/proc
    privileged: true
    ports:
      - "4317:4317" # OTLP gRPC receiver
      - "4318:4318" # OTLP HTTP receiver
      - "8889:8889" # Prometheus metrics endpoint
      - "13133:13133" # Health check
      - "1777:1777" # Pprof
      - "55679:55679" # Zpages
    depends_on:
      - opensearch
      - data-prepper
      - prometheus

  # ========== TRACE SIMULATOR (Optional) ==========
  microsim:
    image: yurishkuro/microsim:v0.6.0@sha256:fd75a9b3dd1bb4d7d305a562edeac60051a7fec784b898ff7ab834eacc73f41e
    networks:
      - backend
    command: "-d 24h -s 500ms"
    environment:
      - OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://otel-collector:4318/v1/traces
    depends_on:
      - otel-collector

networks:
  backend:

volumes:
  prometheus-data:
  esdata:
    driver: local
